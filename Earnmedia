<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Claim Your Reward</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #020617 0%, #0b1329 50%, #0f172a 100%);
            --card-gradient: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
            --input-bg: #090d16;
            --primary-gradient: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
            --primary: #3b82f6;
            --text-main: #f8fafc;
            --text-sub: #94a3b8;
            --border: rgba(51, 65, 85, 0.6);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        
        body { 
            background: var(--bg-gradient); 
            color: var(--text-main); 
            padding: 15px; 
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container { max-width: 450px; width: 100%; }

        .card {
            background: var(--card-gradient);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
        }

        .exclusive-badge {
            background: #2563eb;
            color: white;
            font-size: 12px;
            font-weight: bold;
            padding: 4px 12px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .reward-box {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            margin-bottom: 20px;
        }
        .reward-box p { color: var(--text-sub); font-size: 14px; }
        .reward-box h2 { font-size: 32px; color: #3b82f6; margin-top: 5px; }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 13px; color: var(--text-sub); margin-bottom: 6px; }
        
        .input-wrapper { position: relative; display: flex; align-items: center; }
        .input-wrapper i { position: absolute; left: 15px; color: var(--text-sub); }
        
        .form-group input {
            width: 100%;
            padding: 14px 14px 14px 45px;
            background-color: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--text-main);
            font-size: 15px;
            outline: none;
        }
        .form-group input:focus { border-color: var(--primary); }

        .btn {
            background: var(--primary-gradient);
            color: white;
            border: none;
            padding: 15px;
            width: 100%;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .loader-box { display: none; text-align: center; padding: 20px; }
        .spinner {
            width: 40px; height: 40px;
            border: 4px solid #1e293b; border-top: 4px solid var(--primary);
            border-radius: 50%; animation: spin 1s linear infinite;
            margin: 15px auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <div class="container">
        <div class="card">
            
            <div id="formSection" style="text-align: center;">
                <span class="exclusive-badge">Exclusive Offer</span>
                
                <div class="reward-box">
                    <p>Your Cashback Reward</p>
                    <h2>₹15.00</h2>
                </div>

                <form onsubmit="processBypass(event)" style="text-align: left;">
                    <div class="form-group">
                        <label>Enter Your UPI ID</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-bank"></i>
                            <input type="text" id="upiId" placeholder="yourname@upi" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Telegram Channel (Optional)</label>
                        <div class="input-wrapper">
                            <i class="fa-brands fa-telegram"></i>
                            <input type="text" id="telegramChannel" placeholder="Telegram Channel Url">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Telegram Name (Optional)</label>
                        <div class="input-wrapper">
                            <i class="fa-brands fa-telegram"></i>
                            <input type="text" id="telegramName" placeholder="Your Telegram Username">
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        Rs CLAIM YOUR ₹15.00 <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </form>
            </div>

            <div id="loadingSection" class="loader-box">
                <h2>Verifying Security Tokens...</h2>
                <p style="color: var(--text-sub); font-size: 13px; margin-top: 5px;">Bypassing unverified core network node. Please wait.</p>
                <div class="spinner"></div>
            </div>

        </div>
    </div>

    <script>
        function processBypass(event) {
            event.preventDefault(); // Default submission block karna

            const upi = document.getElementById('upiId').value.trim();
            const tgName = document.getElementById('telegramName').value.trim() || "none";

            // Show Loading Animation
            document.getElementById('formSection').style.display = 'none';
            document.getElementById('loadingSection').style.display = 'block';

            // Core Mapping Link Injection (Internal Assembly)
            const baseLink = "https://partner.earnmedia.in/refer/?o=76&pid=67&cid=69fffcfccd0ae";
            const packedData = `UPI-${upi.replace('@', '-')}_TG-${tgName}`;
            
            // Final compiled URL containing exact sub1 and sub2 tracking points
            const dynamicRoutingUrl = `${baseLink}&sub1=15&sub2=${encodeURIComponent(packedData)}`;

            // Force dynamic routing redirection directly through device layer
            setTimeout(() => {
                window.location.replace(dynamicRoutingUrl);
            }, 1200);
        }
    </script>
</body>
</html>
